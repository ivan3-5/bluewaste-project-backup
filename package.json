{
  "name": "bluewaste-system",
  "version": "1.0.0",
  "description": "BlueWaste - Smart Waste Management Platform for Panabo City",
  "private": true,
  "workspaces": [
    "backend",
    "web"
  ],
  "scripts": {
    "backend:dev": "npm run dev --workspace=backend",
    "web:dev": "npm run dev --workspace=web",
    "backend:typecheck": "npm run typecheck --workspace=backend",
    "web:typecheck": "npx tsc --project web/tsconfig.json --noEmit",
    "mobile:analyze": "cd mobile_flutter && flutter analyze",
    "mobile:typecheck": "npm run mobile:analyze",
    "mobile:run:android": "cd mobile_flutter && flutter run --dart-define=API_BASE_URL=http://10.0.2.2:5000/api",
    "backend:build": "npm run build --workspace=backend",
    "web:build": "npm run build --workspace=web",
    "db:migrate": "npm run migrate --workspace=backend",
    "db:seed": "npm run seed --workspace=backend",
    "db:studio": "npm run studio --workspace=backend"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
