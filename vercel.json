{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.ts"
    },
    {
      "src": "/_next/(.*)",
      "dest": "web/_next/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ]
}
