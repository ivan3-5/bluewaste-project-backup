{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/[...path].ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path].ts"
    },
    {
      "source": "/dashboard/reports/:id",
      "destination": "/web/dashboard/report?id=:id"
    },
    {
      "source": "/",
      "destination": "/web"
    },
    {
      "source": "/:path*",
      "destination": "/web/:path*"
    }
  ]
}
